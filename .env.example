# ============================================================
# InvestingAssistant — Local Development Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# You only need ONE LLM provider key to get started (Gemini recommended).
# ============================================================

# Environment: local, dev, prod
INVESTING_ASSISTANT_ENV=local

# --- LLM API Keys (at least one required) ---

# Google Gemini (recommended — free tier: 20 req/day)
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI (pay-as-you-go, ~$0.15/1M input tokens for gpt-4o-mini)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (pay-as-you-go, ~$0.80/1M input tokens for Haiku 4.5)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Reddit API (optional — for Reddit scraper) ---
# Create an app: https://www.reddit.com/prefs/apps
# Select "script" type, use http://localhost:8000 as redirect URI
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- X / Twitter API (optional — for X scraper) ---
# Apply for access: https://developer.x.com/en/portal/dashboard
XBEARER_TOKEN=

# --- AWS (local development — no changes needed) ---
AWS_REGION=us-east-1
S3_RAW_BUCKET=investingassistant-raw-local
